{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import"],
  "jsPlugins": ["./scripts/oxlint-style-plugin.js"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "env": {
    "builtin": true,
    "node": true,
    "es2024": true
  },
  "rules": {
    "no-console": "off",
    "no-magic-numbers": "off",
    "no-ternary": "off",
    "id-length": "off",
    "unicorn/no-null": "off",
    "unicorn/prefer-string-raw": "off",
    "curly": ["error", "all"],
    "style/single-quote": "error",
    "style/semi": "error"
  },
  "ignorePatterns": ["node_modules", "dist"]
}
